# Bar chart of cell cycle phase proportions
phase_props <- soxOE@meta.data %>%
  group_by(overexpress, Phase) %>%
  summarise(n = n(), .groups = "drop") %>%
  group_by(overexpress) %>%
  mutate(proportion = n / sum(n))

ggplot(phase_props, aes(x = overexpress, y = proportion, fill = Phase)) +
  geom_bar(stat = "identity") +
  scale_fill_manual(values = c("G1" = "#4DAF4A", "S" = "#377EB8", "G2M" = "#E41A1C")) +
  labs(x = "Condition", y = "Proportion", fill = "Cell Cycle Phase") +
  theme_classic()

# DE Genes
common_celltypes <- intersect(
  unique(soxOE$Celltype[soxOE$overexpress == "GFP"]),
  unique(soxOE$Celltype[soxOE$overexpress == "Sox8Sox9"])
)

# Run FindMarkers for each common cell type
Idents(soxOE) <- "overexpress"

markers_by_celltype <- list()

for(ct in common_celltypes) {
  soxOE_sub <- subset(soxOE, Celltype == ct)
  Idents(soxOE_sub) <- "overexpress"
  
  markers_by_celltype[[ct]] <- FindMarkers(soxOE_sub,
                                           ident.1 = "Sox8Sox9",
                                           ident.2 = "GFP") %>%
    filter(p_val_adj < 0.05) %>%
    mutate(celltype = ct)
}

output_dir <- "E:/Sox KO"

for(ct in names(markers_by_celltype)) {
  filename <- paste0("e14p0_sox89OE_", ct, "_DEG_padj005.csv")
  write.csv(markers_by_celltype[[ct]], 
            file = file.path(output_dir, filename),
            row.names = TRUE)
}

