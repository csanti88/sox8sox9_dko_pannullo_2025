#Heatmap DE genes in RPC showing Sox8/9 direct binding
rpc <- subset(soxOE, Celltype == "RPC")
pseudo_bulk <- AggregateExpression(rpc, 
                                   group.by = "orig.ident",
                                   assay = "RNA",
                                   slot = "counts",
                                   return.seurat = FALSE)$RNA

pseudo_bulk_de <- pseudo_bulk[rownames(rpcDE), ]
pseudo_bulk_de <- log1p(t(t(pseudo_bulk_de) / colSums(pseudo_bulk_de) * 1e6))
pseudo_bulk_scaled <- t(scale(t(pseudo_bulk_de)))
sample_anno <- data.frame(
  Condition = ifelse(grepl("GFP", colnames(pseudo_bulk_scaled)), "GFP", "Sox8Sox9"),
  row.names = colnames(pseudo_bulk_scaled)
)

genes_to_label <- c("Sox6", "Nfia", "Nfib", "Igf2bp1", "Foxn4", "Fgf15", 
                    "Fezf2", "Slc15a2", "Enpp2", "Cd44", "Fosb", "Clic1", 
                    "Denr", "Imt2a", "Fbn2", "Plagl1")
label_idx <- which(rownames(pseudo_bulk_scaled) %in% genes_to_label)

Heatmap(pseudo_bulk_scaled,
        name = "Expression",
        col = viridis(100, option = "magma"),
        top_annotation = HeatmapAnnotation(
          Condition = sample_anno$Condition,
          col = list(Condition = c("GFP" = "#4484DF", "Sox8Sox9" = "#DF9144"))
        ),
        right_annotation = rowAnnotation(
          mark = anno_mark(at = label_idx,
                           labels = rownames(pseudo_bulk_scaled)[label_idx],
                           labels_gp = gpar(fontsize = 8))
        ),
        cluster_columns = FALSE,
        cluster_rows = TRUE,
        show_row_names = FALSE,
        show_column_names = TRUE,
        row_names_gp = gpar(fontsize = 6),
        border = FALSE)
